generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

/////////////////////////////////
//           ADMIN
/////////////////////////////////
model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/////////////////////////////////
//           CONTENT
/////////////////////////////////

// ─── Hero Content ───

model HeroContent {
  id         String   @id @default(uuid())
  badge      String
  firstName  String
  secondName String
  phrases    String[]
  subtitle   String
  uniqueKey  String   @unique @default("hero")
}

// ─── Testimonial ───
model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String
  quote     String   @db.Text
  image     String?
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isVisible])
  @@index([createdAt])
}

// ─── About Content ───
model AboutContent {
  id           String        @id @default(uuid())
  bio          String        @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  skills       Skill[]
  experiences  Experience[]
  educations   Education[]
  achievements Achievement[]
  languages    Language[]
}

// ─── Skill ───
model Skill {
  id             String        @id @default(uuid())
  category       String // "Frontend, Backend, Database"
  items          String[]
  aboutContentId String?
  aboutContent   AboutContent? @relation(fields: [aboutContentId], references: [id], onDelete: Cascade)

  @@index([category])
}

// ─── Experience ───

model Experience {
  id             String        @id @default(uuid())
  role           String
  company        String
  period         String
  description    String        @db.Text
  aboutContentId String?
  aboutContent   AboutContent? @relation(fields: [aboutContentId], references: [id], onDelete: Cascade)
}

// ─── Education ───
model Education {
  id             String        @id @default(uuid())
  degree         String
  school         String
  year           String
  aboutContentId String?
  aboutContent   AboutContent? @relation(fields: [aboutContentId], references: [id], onDelete: Cascade)
}

// ─── Achievement ───
model Achievement {
  id             String        @id @default(uuid())
  issuer         String
  year           String
  aboutContentId String?
  aboutContent   AboutContent? @relation(fields: [aboutContentId], references: [id], onDelete: Cascade)
}

// ─── Language ───
model Language {
  id             String        @id @default(uuid())
  name           String
  proficiency    String
  aboutContentId String?
  aboutContent   AboutContent? @relation(fields: [aboutContentId], references: [id], onDelete: Cascade)
}

/////////////////////////////////
//       CONTACT MESSAGE
/////////////////////////////////
model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Snapshot the sender's location at message time so old messages
  // still display the original country/city even if the visitor record changes later.
  senderCountry     String?
  senderCity        String?
  senderCountryCode String?

  // Keep the relation as well so the admin can inspect the linked visitor record if needed.
  visitorId String?
  visitor   Visitor? @relation(fields: [visitorId], references: [id], onDelete: SetNull)

  @@index([read]) // For unread count and filter
  @@index([createdAt(sort: Desc)]) // For sorting 
  @@index([senderCountryCode])
}

/////////////////////////////////
//       ARTICLE
/////////////////////////////////

model Article {
  id        String        @id @default(uuid())
  title     String
  tag       String
  status    PublishStatus @default(DRAFT)
  image     String?
  content   String        @db.Text
  slug      String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum PublishStatus {
  DRAFT
  PUBLISHED
}

/////////////////////////////////
//       PROJECT
/////////////////////////////////

model Project {
  id          String        @id @default(uuid())
  image       String?
  title       String
  description String        @db.Text
  year        String
  status      PublishStatus @default(DRAFT)
  isVisible   Boolean       @default(true)
  tags        String[]
  githubUrl   String?
  liveUrl     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

/////////////////////////////////
//        VISITOR
/////////////////////////////////

model Visitor {
  id          String           @id @default(uuid())
  ipAddress   String
  country     String?
  city        String?
  userAgent   String?
  countryCode String?
  createdAt   DateTime         @default(now())
  visits      SiteVisit[]
  messages    ContactMessage[]

  @@index([ipAddress])
  @@index([countryCode])
}

model SiteVisit {
  id        String  @id @default(uuid())
  visitorId String
  visitor   Visitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([visitorId])
  @@index([createdAt(sort: Desc)])
}
